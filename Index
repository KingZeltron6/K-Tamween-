        <div class="time-grid" id="timeGrid"></div>
      </div>

      <!-- Payment -->
      <div class="fsec">
        <h3>💳 Payment <span style="font-size:.7rem;color:var(--dim);font-family:var(--fb);font-weight:400;margin-left:6px">Demo — no real charge</span></h3>
        <div class="fg-chk"><label>Cardholder Name</label><input class="fi-chk" id="chkCardName" placeholder="Name on card"></div>
        <div class="fg-chk"><label>Card Number</label><input class="fi-chk" id="chkCardNum" placeholder="1234 5678 9012 3456" maxlength="19" oninput="fmtCard(this)"></div>
        <div class="frow">
          <div class="fg-chk"><label>Expiry</label><input class="fi-chk" id="chkExpiry" placeholder="MM / YY" maxlength="7" oninput="fmtExpiry(this)"></div>
          <div class="fg-chk"><label>CVV</label><input class="fi-chk" id="chkCvv" type="password" placeholder="•••" maxlength="4"></div>
        </div>
        <p style="font-size:.72rem;color:var(--dim);margin-top:.5rem">🔒 Demo only — no real payment processed</p>
      </div>
    </div>

    <!-- Summary sidebar -->
    <div class="ord-sum" id="ordSummary"></div>
  </div>
  <footer>
    <div class="container footer-inner">
      <div class="f-logo">K-<span>Tamween</span></div>
      <div class="f-team"><strong>Team:</strong> Hassan · Yousif · Waleed · Ali</div>
      <div class="f-note">🔒 Secure Demo Checkout</div>
    </div>
  </footer>
</div>

<!-- ═══ VIEW: CONFIRM ═══ -->
<div id="viewConfirm" class="view">
  <div class="container confirm-wrap">
    <div class="confirm-card">
      <div class="conf-icon">✅</div>
      <h2>Order Confirmed!</h2>
      <p class="csub" id="confMsg">Your order has been placed successfully.</p>
      <div class="order-ref">
        <div class="ref-label">Order Reference Number</div>
        <div class="ref-num" id="confRef">KT-000000</div>
      </div>
      <div class="conf-details" id="confDetails"></div>
      <div class="conf-btns">
        <button class="btn-track" onclick="showToast('📦 Order tracking will be available in a future update!','📦')">Track Order</button>
        <button class="btn-back" onclick="shopAgain()">← Back to Shop</button>
      </div>
    </div>
  </div>
  <footer>
    <div class="container footer-inner">
      <div class="f-logo">K-<span>Tamween</span></div>
      <div class="f-team"><strong>Team:</strong> Hassan · Yousif · Waleed · Ali</div>
      <div class="f-note">Demo Platform</div>
    </div>
  </footer>
</div>

<script>
/* ── PRODUCTS ─────────────────────────────────────── */
const P = [
  {id:'rice',   cat:'essentials', e:'🍚', bg:'#14201a', n:'Basmati Rice',          u:'per kg',  q:5, p:.120, m:.350},
  {id:'flour',  cat:'essentials', e:'🌾', bg:'#201e12', n:'All-Purpose Flour',      u:'per kg',  q:5, p:.080, m:.220},
  {id:'sugar',  cat:'essentials', e:'🍬', bg:'#1e1220', n:'White Sugar',             u:'per kg',  q:2, p:.100, m:.280},
  {id:'oil',    cat:'essentials', e:'🫙', bg:'#1e1c0c', n:'Sunflower Oil',           u:'per L',   q:2, p:.150, m:.480},
  {id:'beef',   cat:'meat',       e:'🥩', bg:'#200e12', n:'Minced Beef',             u:'per kg',  q:3, p:1.200,m:2.800},
  {id:'chick',  cat:'meat',       e:'🍗', bg:'#1e180a', n:'Whole Chicken',           u:'per kg',  q:4, p:.400, m:.950},
  {id:'lamb',   cat:'meat',       e:'🍖', bg:'#1a0c14', n:'Lamb Chops',              u:'per kg',  q:2, p:1.500,m:3.200},
  {id:'fish',   cat:'meat',       e:'🐟', bg:'#0c1620', n:'Fresh Fish',              u:'per kg',  q:2, p:.600, m:1.500},
  {id:'tom',    cat:'canned',     e:'🍅', bg:'#200a0a', n:'Tomato Paste',            u:'per can', q:4, p:.080, m:.220},
  {id:'chkp',   cat:'canned',     e:'🫘', bg:'#181608', n:'Chickpeas',               u:'per can', q:4, p:.070, m:.180},
  {id:'tuna',   cat:'canned',     e:'🐠', bg:'#0a1420', n:'Tuna in Oil',             u:'per can', q:4, p:.150, m:.380},
  {id:'lentil', cat:'canned',     e:'🟤', bg:'#1a1008', n:'Red Lentils',             u:'per can', q:4, p:.060, m:.160},
  {id:'milk',   cat:'healthy',    e:'🥛', bg:'#0c1820', n:'Low-Fat Milk',            u:'per L',   q:4, p:.200, m:.520},
  {id:'dates',  cat:'healthy',    e:'🌴', bg:'#181404', n:'Medjool Dates',            u:'per kg',  q:1, p:.500, m:1.200},
  {id:'bread',  cat:'healthy',    e:'🍞', bg:'#1a1406', n:'Whole Grain Bread',       u:'per pack',q:2, p:.180, m:.450},
  {id:'olive',  cat:'healthy',    e:'🫒', bg:'#0a1808', n:'Extra Virgin Olive Oil',  u:'per L',   q:1, p:.800, m:2.100},
];

const CAT = {all:'All',essentials:'Essentials',meat:'Meat & Poultry',canned:'Canned Goods',healthy:'Healthy'};
const CICO = {all:'🏪',essentials:'🍚',meat:'🥩',canned:'🥫',healthy:'🥛'};

/* ── STATE ────────────────────────────────────────── */
const S = {
  view:'home', user:null, cart:{},
  cat:'all', search:'', method:'delivery',
  date:null, time:null
};

/* ── UTILS ────────────────────────────────────────── */
const kwd = n => 'KWD ' + n.toFixed(3);
const qty  = id => S.cart[id] || 0;
const cCount = () => Object.values(S.cart).reduce((a,v)=>a+v,0);
const cTotal = () => P.reduce((a,p)=>a + p.p * qty(p.id),0);
const cMkt   = () => P.reduce((a,p)=>a + p.m * qty(p.id),0);
const cSave  = () => cMkt() - cTotal();
const savePct = p => Math.round((p.m-p.p)/p.m*100);

/* ── NAV ──────────────────────────────────────────── */
function showView(v) {
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  const id = 'view' + v[0].toUpperCase() + v.slice(1);
  document.getElementById(id).classList.add('active');
  S.view = v;
  window.scrollTo({top:0,behavior:'smooth'});
  closeAll();
  if(v==='home') renderHome();
  if(v==='shop') renderShop();
  if(v==='checkout') { renderSummary(); buildDates(); }
}

function goShopCat(c) { S.cat=c; showView('shop'); }

/* ── CART ─────────────────────────────────────────── */
function toggleCart() {
  const d = document.getElementById('cartDrawer');
  const o = document.getElementById('overlay');
  const open = d.classList.toggle('open');
  o.classList.toggle('show', open);
  if(open) renderCart();
}

function closeAll() {
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('loginModal').classList.remove('show');
}

function renderCart() {
  const el = document.getElementById('cartItems');
  const ft = document.getElementById('cartFoot');
  const items = P.filter(p=>qty(p.id)>0);
  if(!items.length) {
    el.innerHTML=`<div class="cart-empty"><div class="big-icon">🛒</div><p>Your cart is empty.<br>Add items from the shop!</p></div>`;
    ft.style.display='none'; return;
  }
  ft.style.display='block';
  el.innerHTML = items.map(p=>`
    <div class="cart-item">
      <div class="ci-icon" style="background:${p.bg}">${p.e}</div>
      <div class="ci-info">
        <div class="ci-name">${p.n}</div>
        <div><span class="ci-price">${kwd(p.p*qty(p.id))}</span><span class="ci-mkt">${kwd(p.m*qty(p.id))}</span></div>
        <div class="ci-qty">
          <button class="qbtn" onclick="chgQty('${p.id}',-1)">−</button>
          <span class="qnum">${qty(p.id)}</span>
          <button class="qbtn" onclick="chgQty('${p.id}',1)">+</button>
        </div>
      </div>
      <button class="ci-rm" onclick="rmItem('${p.id}')">✕</button>
    </div>`).join('');
  document.getElementById('cartSavingsVal').textContent = kwd(cSave());
  document.getElementById('cartTotalVal').textContent   = kwd(cTotal());
}

function updBadge() {
  const n=cCount(), b=document.getElementById('cartBadge');
  if(n>0){b.textContent=n;b.style.display='flex';}else b.style.display='none';
}

function chgQty(id, d) {
  const p = P.find(x=>x.id===id);
  const next = Math.max(0, Math.min(p.q, qty(id)+d));
  if(next===0) delete S.cart[id]; else S.cart[id]=next;
  updBadge(); renderCart(); refreshCard(id);
}

function rmItem(id) { delete S.cart[id]; updBadge(); renderCart(); refreshCard(id); }

function addToCart(id) {
  const p = P.find(x=>x.id===id);
  if(qty(id)>=p.q){showToast('⚠️ Monthly quota reached for this item','⚠️');return;}
  S.cart[id] = qty(id)+1;
  updBadge(); refreshCard(id);
  showToast(`${p.e} ${p.n} added to cart!`, p.e);
}

function refreshCard(id) {
  document.querySelectorAll(`[data-pid="${id}"]`).forEach(el=>{
    const p=P.find(x=>x.id===id), q=qty(id);
    const act=el.querySelector('.pact');
    const qu=el.querySelector('.pqused');
    const qf=el.querySelector('.pq-fill');
    if(act) act.innerHTML=buildAction(p);
    if(qu)  qu.textContent=`${q}/${p.q} ${p.u.replace('per ','')}`;
    if(qf)  qf.style.width=`${(q/p.q)*100}%`;
  });
}

/* ── PRODUCT CARD ─────────────────────────────────── */
function buildAction(p) {
  const q=qty(p.id);
  if(!q) return `<button class="btn-add" onclick="addToCart('${p.id}')">＋ Add to Cart</button>`;
  return `<div class="in-cart-ctrl">
    <button class="qbtn" onclick="chgQty('${p.id}',-1)">−</button>
    <span class="qnum">${q}</span>
    <button class="qbtn" onclick="chgQty('${p.id}',1)">+</button>
  </div>`;
}

function card(p) {
  const q=qty(p.id), sp=savePct(p);
  return `<div class="pcard" data-pid="${p.id}">
    <div class="pcard-img" style="background:${p.bg}">${p.e}</div>
    <div class="pcard-body">
      <div class="pcard-cat">${CAT[p.cat]}</div>
      <div class="pcard-name">${p.n}</div>
      <div class="pcard-prices">
        <span class="pprice">${kwd(p.p)}</span>
        <span class="punit">${p.u}</span>
        <span class="pmkt">${kwd(p.m)}</span>
      </div>
      <div class="psave">💚 Save ${sp}%</div>
      <div class="pquota">
        <div class="pq-labels"><span>Monthly Quota</span><span class="pqused">${q}/${p.q} ${p.u.replace('per ','')}</span></div>
        <div class="pq-track"><div class="pq-fill" style="width:${(q/p.q)*100}%"></div></div>
      </div>
      <div class="pact">${buildAction(p)}</div>
    </div>
  </div>`;
}

/* ── HOME ─────────────────────────────────────────── */
function renderHome() {
  const feat = [P[0],P[4],P[8],P[12],P[3],P[6],P[10],P[14]];
  document.getElementById('homeFeatured').innerHTML = feat.map(card).join('');
}

/* ── SHOP ─────────────────────────────────────────── */
function renderShop() {
  // Category buttons
  document.getElementById('shopCats').innerHTML = Object.keys(CAT).map(c=>
    `<button class="scat-btn ${S.cat===c?'active':''}" onclick="setShopCat('${c}')">${CICO[c]} ${CAT[c]}</button>`
  ).join('');

  let items = [...P];
  if(S.cat!=='all') items=items.filter(p=>p.cat===S.cat);
  if(S.search){const q=S.search.toLowerCase();items=items.filter(p=>p.n.toLowerCase().includes(q));}
  const sv = document.getElementById('sortSelect')?.value||'default';
  if(sv==='price-asc')  items.sort((a,b)=>a.p-b.p);
  if(sv==='price-desc') items.sort((a,b)=>b.p-a.p);
  if(sv==='savings')    items.sort((a,b)=>(b.m-b.p)-(a.m-a.p));

  document.getElementById('shopCount').textContent = `${items.length} product${items.length!==1?'s':''}`;
  document.getElementById('shopGrid').innerHTML = items.length
    ? items.map(card).join('')
    : '<p style="grid-column:1/-1;text-align:center;padding:4rem;color:var(--sub)">No products found</p>';
}

function setShopCat(c){S.cat=c;renderShop();}
function handleSearch(q){S.search=q;if(S.view!=='shop')showView('shop');else renderShop();}

/* ── CHECKOUT ─────────────────────────────────────── */
function goToCheckout() {
  if(!cCount()){showToast('Your cart is empty!','⚠️');return;}
  closeAll();
  if(S.user){
    document.getElementById('chkName').value  = S.user.name;
    document.getElementById('chkCivilId').value = S.user.cid;
  }
  showView('checkout');
}

function selectMethod(m) {
  S.method=m;
  document.getElementById('optD').classList.toggle('sel',m==='delivery');
  document.getElementById('optP').classList.toggle('sel',m==='pickup');
  document.getElementById('addrFields').style.display  = m==='delivery'?'':'none';
  document.getElementById('pickupFields').style.display = m==='pickup'?'':'none';
}

function buildDates() {
  const DAYS=['Sun','Mon','Tue','Wed','Thu'], MONS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const dates=[];
  const d=new Date(); d.setDate(d.getDate()+1);
  while(dates.length<10){ if(d.getDay()!==5&&d.getDay()!==6) dates.push(new Date(d)); d.setDate(d.getDate()+1); }
  document.getElementById('dateGrid').innerHTML = dates.map((dt,i)=>
    `<div class="dbtn ${i===0?'sel':''}" onclick="pickDate(this,'${dt.toDateString()}')">
      <div class="dday">${DAYS[dt.getDay()]}</div>
      <div class="dnum">${dt.getDate()}</div>
      <div class="dmon">${MONS[dt.getMonth()]}</div>
    </div>`).join('');
  S.date = dates[0].toDateString();
  const slots=['8:00 AM','9:30 AM','11:00 AM','12:30 PM','2:00 PM','3:30 PM'];
  document.getElementById('timeGrid').innerHTML = slots.map((t,i)=>
    `<div class="tbtn ${i===0?'sel':''}" onclick="pickTime(this,'${t}')">${t}</div>`).join('');
  S.time = slots[0];
}

function pickDate(el,d){document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');S.date=d;}
function pickTime(el,t){document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');S.time=t;}

function renderSummary() {
  const items=P.filter(p=>qty(p.id)>0), tot=cTotal(), save=cSave();
  document.getElementById('ordSummary').innerHTML=`
    <h3>🧾 Order Summary</h3>
    <div class="sum-items">${items.map(p=>`
      <div class="sum-item">
        <div class="sum-ico">${p.e}</div>
        <div class="sum-info">
          <div class="sum-iname">${p.n}</div>
          <div class="sum-iqty">${qty(p.id)} × ${kwd(p.p)}</div>
        </div>
        <div class="sum-iprice">${kwd(p.p*qty(p.id))}</div>
      </div>`).join('')}</div>
    <div class="sum-div"></div>
    <div class="sum-row"><span class="sl">Subtotal</span><span class="sv">${kwd(tot)}</span></div>
    <div class="sum-row"><span class="sl">Delivery</span><span class="sv" style="color:var(--green)">FREE</span></div>
    <div class="sum-div"></div>
    <div class="sum-row total"><span class="sl">Total</span><span class="sv">${kwd(tot)}</span></div>
    <div class="sum-save"><div class="sn">${kwd(save)}</div><div class="sl2">saved vs market prices 💚</div></div>
    <button class="btn-order" onclick="placeOrder()">→ Place Order</button>
    <div class="sec-note">🔒 Secure demo checkout</div>`;
}

function placeOrder() {
  const name  = document.getElementById('chkName').value.trim();
  const phone = document.getElementById('chkPhone').value.trim();
  if(!name)  {showToast('Please enter your name','⚠️');return;}
  if(!phone) {showToast('Please enter your mobile number','⚠️');return;}
  if(S.method==='delivery'){
    const gov=document.getElementById('chkGov').value;
    const blk=document.getElementById('chkBlock').value.trim();
    const str=document.getElementById('chkStreet').value.trim();
    const bld=document.getElementById('chkBldg').value.trim();
    if(!gov||!blk||!str||!bld){showToast('Please complete your delivery address','⚠️');return;}
  } else {
    if(!document.getElementById('chkBranch').value){showToast('Please select a pickup branch','⚠️');return;}
  }
  if(!S.date||!S.time){showToast('Please select a date and time','⚠️');return;}

  const ref = 'KT-' + Math.floor(100000+Math.random()*900000);
  const items= P.filter(p=>qty(p.id)>0);
  const addr = S.method==='delivery'
    ? `${document.getElementById('chkGov').value}, Block ${document.getElementById('chkBlock').value}, St ${document.getElementById('chkStreet').value}, Bldg ${document.getElementById('chkBldg').value}`
    : document.getElementById('chkBranch').value;
  const tot=cTotal(), save=cSave();

  document.getElementById('confRef').textContent = ref;
  document.getElementById('confMsg').textContent  = `Thank you, ${name}! Your order has been placed. A confirmation SMS will be sent to ${phone}.`;
  document.getElementById('confDetails').innerHTML=`
    <div class="cdr"><span class="dl">📦 Items</span><span class="dv">${items.length} products (${cCount()} units)</span></div>
    <div class="cdr"><span class="dl">${S.method==='delivery'?'🚚 Deliver to':'🏪 Pickup from'}</span><span class="dv">${addr}</span></div>
    <div class="cdr"><span class="dl">📅 Scheduled</span><span class="dv">${S.date} · ${S.time}</span></div>
    <div class="cdr"><span class="dl">💰 Total Paid</span><span class="dv" style="color:var(--blue-lt)">${kwd(tot)}</span></div>
    <div class="cdr"><span class="dl">💚 Total Saved</span><span class="dv" style="color:var(--green)">${kwd(save)}</span></div>`;

  S.cart={}; updBadge(); showView('confirm');
}

function shopAgain(){S.cat='all';showView('shop');}

/* ── LOGIN ────────────────────────────────────────── */
function openLogin(){
  document.getElementById('loginModal').classList.add('show');
  document.getElementById('overlay').classList.add('show');
}
function closeLogin(){
  document.getElementById('loginModal').classList.remove('show');
  document.getElementById('overlay').classList.remove('show');
}
function doLogin(){
  const name=document.getElementById('loginName').value.trim();
  const cid =document.getElementById('loginCivilId').value.trim();
  if(!name)          {showToast('Please enter your name','⚠️');return;}
  if(!/^\d{12}$/.test(cid)){showToast('Civil ID must be exactly 12 digits','⚠️');return;}
  S.user={name,cid};
  document.getElementById('loginNavBtn').style.display='none';
  const chip=document.getElementById('userChip');
  chip.style.display='flex';
  document.getElementById('userName').textContent=name.split(' ')[0];
  document.getElementById('userAvatar').textContent=name[0].toUpperCase();
  closeLogin();
  showToast(`👋 Welcome, ${name.split(' ')[0]}!`,'👋');
  showView('shop');
}
function logoutUser(){
  S.user=null;
  document.getElementById('loginNavBtn').style.display='flex';
  document.getElementById('userChip').style.display='none';
  showToast('Signed out','👋'); showView('home');
}

/* ── TOAST ────────────────────────────────────────── */
function showToast(msg,icon='✅'){
  const t=document.getElementById('toast');
  document.getElementById('toastMsg').textContent=msg;
  document.getElementById('toastIcon').textContent=icon;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t=setTimeout(()=>t.classList.remove('show'),2800);
}

/* ── FORMAT HELPERS ───────────────────────────────── */
function fmtCard(el){let v=el.value.replace(/\D/g,'').slice(0,16);el.value=v.replace(/(.{4})/g,'$1 ').trim();}
function fmtExpiry(el){let v=el.value.replace(/\D/g,'').slice(0,4);if(v.length>=3)v=v.slice(0,2)+' / '+v.slice(2);el.value=v;}

/* ── INIT ─────────────────────────────────────────── */
renderHome();
</script>
</body>
</html>
